	<select id="getSecret" resultClass="secret">
		SELECT *
		FROM d_secret_t
		WHERE validflag > 0 and id=1
	</select>
	<!-- 修改 -->
	<update id="updateSecret" parameterClass="secret">
		UPDATE d_secret_t
		SET secret_text='$secret_text$',
		updateoperator='$updateoperator$',updatetime='$updatetime$',memo='$memo$'
		WHERE id = $id$
	</update>
</sqlMap>