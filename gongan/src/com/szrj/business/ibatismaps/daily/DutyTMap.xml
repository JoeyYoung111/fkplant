<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE sqlMap PUBLIC "-//iBATIS.com//DTD SQL Map 2.0//EN"
        "http://ibatis.apache.org/dtd/sql-map-2.dtd">
        
<sqlMap namespace="duty">
	<typeAlias alias="duty" type="com.szrj.business.model.daily.Duty"/>
	<typeAlias alias="secret" type="com.szrj.business.model.daily.Secret"/>
	<select id="getByIdOrDepartid" parameterClass="duty" resultClass="duty">
		SELECT *
		FROM d_duty_t
		WHERE validflag > 0
		<dynamic prepend="">
			<isNotEqual prepend="AND" property="id" compareValue="0">
	        	id=$id$
	        </isNotEqual>
			<isNotEqual prepend="AND" property="departid" compareValue="0">
	        	departid=$departid$
	        </isNotEqual>
		</dynamic>
	</select>
	<select id="getAllDuty" resultClass="duty">
		SELECT *
		FROM d_duty_t
		WHERE validflag > 0
		ORDER BY id
	</select>
	<!-- 修改 -->
	<update id="update" parameterClass="duty">
		UPDATE d_duty_t
		SET $field$='$fieldString$',
		updateoperator='$updateoperator$',updatetime='$updatetime$',memo='$memo$'
		WHERE id = $id$
	</update>
